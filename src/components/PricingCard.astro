---
interface Feature {
  text: string;
  highlight?: boolean;
}

interface Props {
  title: string;
  subtitle: string;
  price: string;
  priceSuffix?: string;
  extraLabel?: string;
  features: Feature[];
  ctaText: string;
  ctaHref?: string;
  ctaTier?: string;
  highlighted?: boolean;
}

const {
  title,
  subtitle,
  price,
  priceSuffix,
  extraLabel,
  features,
  ctaText,
  ctaHref,
  ctaTier,
  highlighted = false,
} = Astro.props;

// CSS classes based on highlighted prop
const cardClasses = highlighted
  ? "rounded-3xl bg-neutral-50 border-2 border-blue-600 p-8 flex flex-col justify-between relative overflow-hidden shadow-[0_10px_30px_rgba(37,99,235,0.05)] transition-all duration-300 hover:scale-[1.01] hover:shadow-[0_15px_35px_rgba(37,99,235,0.1)]"
  : "rounded-3xl bg-neutral-50 border border-neutral-200/50 p-8 flex flex-col justify-between relative overflow-hidden transition-all duration-300 hover:border-neutral-300 hover:shadow-md group";

const buttonClasses = highlighted
  ? "block w-full text-center bg-blue-600 hover:bg-blue-700 active:scale-[0.98] text-white py-2.5 px-4 rounded-xl text-xs font-semibold shadow-md transition duration-150"
  : "block w-full text-center bg-neutral-100 hover:bg-neutral-200 active:scale-[0.98] text-neutral-800 py-2.5 px-4 rounded-xl text-xs font-semibold border border-neutral-200 transition duration-150";

const isExternal = ctaHref && (ctaHref.startsWith("http://") || ctaHref.startsWith("https://"));
---


<div class={cardClasses}>
  {highlighted && (
    <div class="absolute -top-12 -right-12 w-24 h-24 bg-blue-500/5 rounded-full blur-xl"></div>
  )}

  <div class="space-y-6">
    <div>
      <div class="flex items-center gap-2">
        <h3 class="text-2xl font-extrabold text-neutral-900">{title}</h3>
      </div>
      <p class="text-xs text-neutral-500 mt-2 leading-relaxed">
        {subtitle}
      </p>
    </div>

    <div class="space-y-1">
      <div class="flex items-baseline">
        <span class="text-4xl font-extrabold text-neutral-900">{price}</span>
        {priceSuffix && <span class="text-xs text-neutral-500 ml-2">{priceSuffix}</span>}
      </div>
      {extraLabel && (
        <div class="text-[10px] text-blue-600 font-semibold font-mono">
          {extraLabel}
        </div>
      )}
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <ul class="space-y-3.5 text-xs text-neutral-600">
        {features.map((feature) => (
          <li class="flex items-center gap-2.5">
            <svg
              class="w-4 h-4 text-blue-600 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"
              />
            </svg>
            {feature.highlight ? (
              <span class="font-semibold text-neutral-900">{feature.text}</span>
            ) : (
              <span>{feature.text}</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="mt-8">
    {ctaHref ? (
      <a
        href={ctaHref}
        target={isExternal ? "_blank" : undefined}
        rel={isExternal ? "noopener" : undefined}
        class={buttonClasses}
      >
        {ctaText}
      </a>
    ) : (
      <button class={buttonClasses} data-checkout-tier={ctaTier}>
        {ctaText}
      </button>
    )}
  </div>
</div>
