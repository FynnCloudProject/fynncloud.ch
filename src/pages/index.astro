  <!-- Unified Checkout Modal -->
  <div
    id="checkout-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4 overflow-y-auto"
  >
    <div
      class="bg-white rounded-3xl w-full max-w-lg p-6 relative shadow-2xl my-auto text-neutral-900 flex flex-col gap-4"
    >
      <!-- Close Button -->
      <button
        id="btn-close-checkout-modal"
        class="absolute top-4 right-4 text-neutral-400 hover:text-neutral-900 transition cursor-pointer"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <h3 class="text-xl font-bold text-neutral-900 mb-1" id="checkout-modal-title">
        Complete Subscription
      </h3>

      <!-- Order Summary Card -->
      <div
        class="bg-neutral-50 border border-neutral-200/80 rounded-2xl p-4 flex justify-between items-center text-sm text-neutral-900"
      >
        <div>
          <span class="font-bold text-neutral-800" id="checkout-summary-plan"
            >Business License</span
          >
          <span
            class="text-xs text-neutral-500 block mt-0.5"
            id="checkout-summary-details">15 Seats • Billed annually</span
          >
        </div>
        <div class="text-right">
          <span
            class="font-bold text-neutral-900 text-base"
            id="checkout-summary-total">$360.00</span
          >
        </div>
      </div>

      <!-- Step 1: Email Input Container -->
      <div id="checkout-email-step" class="space-y-4">
        <!-- Dynamic Seat Selector (Business Only) -->
        <div id="modal-seats-section" class="space-y-3 p-4 bg-neutral-50 rounded-2xl border border-neutral-100 hidden">
          <div class="flex justify-between items-center text-sm">
            <span class="font-bold text-neutral-800">User Seats</span>
            <span class="font-bold text-blue-600" id="modal-seats-display">15 Seats</span>
          </div>
          <input
            type="range"
            id="modal-seats-slider"
            min="5"
            max="100"
            value="15"
            class="w-full h-1.5 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-blue-600 focus:outline-none"
          />
          <div class="flex justify-between text-[10px] text-neutral-450 font-medium">
            <span>Min: 5 Users</span>
            <span>Max: 100 Users</span>
          </div>
        </div>

        <div class="space-y-2">
          <label
            for="checkout-modal-email"
            class="text-xs font-semibold text-neutral-500"
            >Email Address</label
          >
          <input
            type="email"
            id="checkout-modal-email"
            placeholder="you@example.com"
            required
            class="w-full bg-neutral-50 border border-neutral-200 rounded-xl px-4 py-3 text-sm text-neutral-900 focus:outline-none focus:border-blue-600 transition duration-150"
          />
        </div>
        <button
          type="button"
          id="btn-proceed-to-payment"
          class="w-full py-3 px-4 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition flex items-center justify-center gap-2 cursor-pointer"
        >
          Proceed to Payment
        </button>
      </div>

      <!-- Step 2: Stripe Payment Element Container (Hidden initially) -->
      <div id="checkout-payment-step" class="hidden space-y-4">
        <!-- Spinner -->
        <div
          id="checkout-modal-spinner"
          class="flex flex-col items-center justify-center py-8 gap-3"
        >
          <div
            class="animate-spin rounded-full h-8 w-8 border-2 border-neutral-300 border-t-blue-600"
          ></div>
          <p class="text-xs text-neutral-500">Loading secure checkout form...</p>
        </div>

        <!-- Mount container for Stripe Element -->
        <div id="stripe-checkout-mount" class="mb-4 hidden"></div>

        <!-- Submit Button -->
        <button
          id="btn-submit-payment"
          class="hidden w-full py-3 px-4 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50"
        >
          <span id="btn-submit-text">Pay Now</span>
        </button>
      </div>

      <p class="text-[10px] text-neutral-500 text-center leading-relaxed">
        Payments are processed securely via Stripe. Accounts are configured instantly.
      </p>
    </div>
  </div>

  <script define:vars={{ publicApiUrl }} is:inline>
    (() => {
      let stripe = null;
      let checkoutInstance = null;
      let paymentElement = null;
      let selectedTier = "business";
      let selectedQuantity = 15;

      const initCheckoutModal = () => {
        const modal = document.getElementById("checkout-modal");
        const btnClose = document.getElementById("btn-close-checkout-modal");
        const emailStep = document.getElementById("checkout-email-step");
        const paymentStep = document.getElementById("checkout-payment-step");
        const btnProceed = document.getElementById("btn-proceed-to-payment");
        const emailInput = document.getElementById("checkout-modal-email");
        const stripeMount = document.getElementById("stripe-checkout-mount");
        const btnSubmit = document.getElementById("btn-submit-payment");
        const btnSubmitText = document.getElementById("btn-submit-text");
        const spinner = document.getElementById("checkout-modal-spinner");

        const summaryPlan = document.getElementById("checkout-summary-plan");
        const summaryDetails = document.getElementById("checkout-summary-details");
        const summaryTotal = document.getElementById("checkout-summary-total");

        const seatsSection = document.getElementById("modal-seats-section");
        const seatsSlider = document.getElementById("modal-seats-slider");
        const seatsDisplay = document.getElementById("modal-seats-display");

        if (!modal || !btnClose || !emailStep || !paymentStep || !btnProceed || !emailInput || !stripeMount || !btnSubmit || !btnSubmitText || !spinner) {
          return;
        }

        const openModal = (tier, quantity) => {
          selectedTier = tier;
          selectedQuantity = quantity;

          // Update summary text and configure seats selector
          if (tier === "business") {
            summaryPlan.textContent = "Business License";
            summaryDetails.textContent = `${quantity} Seats • Billed annually`;
            summaryTotal.textContent = `$${(quantity * 2 * 12).toLocaleString()}.00`;
            if (seatsSection && seatsSlider && seatsDisplay) {
              seatsSlider.value = quantity;
              seatsDisplay.textContent = `${quantity} Seats`;
              seatsSection.classList.remove("hidden");
            }
          } else {
            summaryPlan.textContent = "Enterprise License";
            summaryDetails.textContent = "Flat-rate Unlimited • Billed annually";
            summaryTotal.textContent = "$2,500.00";
            if (seatsSection) {
              seatsSection.classList.add("hidden");
            }
          }

          // Reset modal state to Step 1 (email input)
          emailStep.classList.remove("hidden");
          paymentStep.classList.add("hidden");
          stripeMount.classList.add("hidden");
          btnSubmit.classList.add("hidden");
          emailInput.value = "";
          btnProceed.disabled = false;
          btnProceed.textContent = "Proceed to Payment";

          modal.classList.remove("hidden");
          modal.classList.add("flex");
        };

        const closeModal = () => {
          modal.classList.add("hidden");
          modal.classList.remove("flex");

          if (paymentElement) {
            paymentElement.destroy();
            paymentElement = null;
          }
          checkoutInstance = null;
        };

        btnClose.addEventListener("click", closeModal);

        if (seatsSlider && seatsDisplay) {
          seatsSlider.addEventListener("input", () => {
            const quantity = parseInt(seatsSlider.value, 10);
            selectedQuantity = quantity;
            seatsDisplay.textContent = `${quantity} Seats`;
            summaryDetails.textContent = `${quantity} Seats • Billed annually`;
            summaryTotal.textContent = `$${(quantity * 2 * 12).toLocaleString()}.00`;
          });
        }

        // Use event delegation for any elements with [data-checkout-tier]
        document.addEventListener("click", (e) => {
          const target = e.target.closest("[data-checkout-tier]");
          if (target) {
            e.preventDefault();
            const tier = target.getAttribute("data-checkout-tier") || "business";
            const quantity = parseInt(target.getAttribute("data-quantity") || "15", 10);
            openModal(tier, quantity);
          }
        });

        btnProceed.addEventListener("click", async () => {
          const email = emailInput.value.trim();
          if (!email) {
            alert("Please enter your email address to continue.");
            return;
          }
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailRegex.test(email)) {
            alert("Please enter a valid email address.");
            return;
          }

          btnProceed.disabled = true;
          btnProceed.textContent = "Processing...";

          try {
            const apiBase = publicApiUrl;
            const res = await fetch(`${apiBase}/api/checkout/intent`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                tier: selectedTier,
                quantity: selectedQuantity,
                email: email,
              }),
            });

            if (!res.ok) {
              const errData = await res.json().catch(() => ({}));
              throw new Error(errData.reason || "Server failed to create checkout session");
            }

            const data = await res.json();
            const clientSecret = data.clientSecret;

            // Transition to Step 2 (payment element loading)
            emailStep.classList.add("hidden");
            paymentStep.classList.remove("hidden");
            spinner.classList.remove("hidden");

            if (!stripe) {
              stripe = window.Stripe("pk_test_51Tr4cWBou1drPkDif1X3wlrwinJbsIee7Ogyzn2n3nGDuN3pjIfxr3gOOgCf2LKOf1NW2hiGUZs7fhYJqkpyjlx800WUWngOjW");
            }

            checkoutInstance = await stripe.initCheckoutElementsSdk({
              clientSecret,
              elementsOptions: {
                appearance: {
                  theme: "stripe",
                  variables: {
                    colorPrimary: "#2563eb",
                    colorBackground: "#ffffff",
                    colorText: "#171717",
                    borderRadius: "12px",
                    fontFamily: "Inter, system-ui, -apple-system, sans-serif",
                  },
                },
              },
            });

            paymentElement = checkoutInstance.createPaymentElement({
              layout: {
                type: "tabs",
                defaultCollapsed: false,
              },
            });
            paymentElement.mount("#stripe-checkout-mount");

            paymentElement.on("ready", () => {
              spinner.classList.add("hidden");
              stripeMount.classList.remove("hidden");
              btnSubmit.classList.remove("hidden");
              btnSubmit.disabled = false;
              btnSubmitText.textContent = "Pay Now";
            });

          } catch (err) {
            console.error("Checkout intent initialization failed:", err);
            alert(err.message || "Failed to initiate payment. Please try again.");
            btnProceed.disabled = false;
            btnProceed.textContent = "Proceed to Payment";
          }
        });

        btnSubmit.addEventListener("click", async () => {
          if (!checkoutInstance) return;
          btnSubmit.disabled = true;
          btnSubmitText.textContent = "Processing...";

          try {
            const { type, actions } = await checkoutInstance.loadActions();
            if (type === "success") {
              const result = await actions.confirm();
              if (result.error) {
                alert(result.error.message || "Payment confirmation failed.");
                btnSubmit.disabled = false;
                btnSubmitText.textContent = "Pay Now";
              }
            } else {
              throw new Error("Failed to load checkout actions");
            }
          } catch (err) {
            console.error("Payment confirmation error:", err);
            alert("An error occurred while confirming payment. Please try again.");
            btnSubmit.disabled = false;
            btnSubmitText.textContent = "Pay Now";
          }
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCheckoutModal);
      } else {
        initCheckoutModal();
      }
    })();
  </script>
</Layout>
