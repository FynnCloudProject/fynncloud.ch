---
import Layout from "../layouts/Layout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import FastCard from "../components/FastCard.astro";
import BenchmarkCard from "../components/BenchmarkCard.astro";
import PricingCard from "../components/PricingCard.astro";

const portalUrl = import.meta.env.PUBLIC_PORTAL_URL || "http://localhost:3000";
---

<Layout>
  <section
    id="hero-section"
    class="w-full bg-black text-white pt-12 pb-16 overflow-hidden relative flex flex-col items-center justify-center border-b border-white/5"
    data-header-theme="dark"
  >
    <div class="w-full max-w-6xl px-6 flex flex-col items-center relative z-10">
      <div class="w-full max-w-3xl flex flex-col items-start">
        <h1
          class="font-semibold text-3xl sm:text-4xl md:text-5xl tracking-tight text-white max-w-3xl leading-tight"
        >
          Self-hosted cloud storage that doesn't feel like 2012.
        </h1>
        <p
          class="mt-4 text-sm sm:text-base text-neutral-300 max-w-2xl leading-relaxed"
        >
          A lightweight, compiled alternative to Nextcloud Enterprise. Built
          with Swift and Vapor to deliver high performance on everything from a
          Raspberry Pi to enterprise servers.
        </p>
      </div>
      <div class="w-full max-w-5xl relative">
        <img
          src="/img/HeroMBPBlackWebsite.png"
          alt="FynnCloud Finder Mockup"
          class="w-full h-auto select-none pointer-events-none drop-shadow-[0_24px_50px_rgba(0,0,0,0.55)]"
        />
      </div>
    </div>
  </section>

  <section
    id="features"
    class="w-full bg-white text-neutral-900 py-24 border-b border-neutral-200/50"
    data-header-theme="light"
  >
    <div class="w-full max-w-5xl mx-auto px-6 flex flex-col mb-12">
      <h2
        class="text-4xl md:text-5xl font-extrabold tracking-tight text-neutral-900"
      >
        Simply beautiful. Entirely native.
      </h2>
      <p class="mt-4 text-neutral-600 leading-relaxed max-w-2xl">
        FynnCloud integrates directly with your operating system, behaving like
        a native system service. Access your files instantly in Finder, sync
        changes in real-time, and share folders without the bloat of traditional
        web interfaces.
      </p>
    </div>

    <div
      id="carousel-1"
      class="carousel-scroller w-full overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-none pb-4"
    >
      <div class="carousel-track flex gap-6 justify-start">
        <FeatureCard
          title="Native macOS integration."
          description="Integrated directly into Finder. Access all your files on-demand without consuming local storage space."
          paddingClass="p-0"
        >
          <img
            src="/img/NativeMacMockup.png"
            alt="FynnCloud Finder Mockup"
            class="w-full h-full object-contain select-none"
          />
        </FeatureCard>

        <FeatureCard
          title="Native sharing."
          description="Share files and folders directly from the Finder context menu. Create secure links, enforce passwords, and set expiration dates."
          paddingClass="p-0"
        >
          <img
            src="/img/NativeShareMockup.png"
            alt="FynnCloud Finder Native Share Popover"
            class="w-full h-full object-contain select-none"
          />
        </FeatureCard>

        <FeatureCard
          title="Snappy web dashboard."
          description="A responsive, modern web interface. Preview documents, manage storage, and invite team members with zero page reloads."
          paddingClass="p-0"
        >
          <img
            src="/img/ModernWebInterfaceMockup.png"
            alt="FynnCloud Web Interface Mockup"
            class="w-full h-full object-contain select-none mt-2"
          />
        </FeatureCard>

        <FeatureCard
          title="Real-time delta sync."
          description="Sync only changed files and structural updates via a sequence-based delta timeline. Save bandwidth and sync updates instantly without scanning whole directories."
          paddingClass="p-0"
        >
          <img
            src="/img/DeltaSyncStatus.png"
            alt="FynnCloud Delta Sync Status"
            class="w-full h-full object-contain select-none"
          />
        </FeatureCard>
      </div>
    </div>

    <div
      class="w-full max-w-5xl mx-auto px-6 flex justify-end gap-2 mt-12 select-none"
    >
      <button
        type="button"
        onclick="document.getElementById('carousel-1').scrollBy({left: -320, behavior: 'smooth'})"
        class="p-2 rounded-full border border-neutral-200 bg-white hover:bg-neutral-50 text-neutral-300 hover:text-neutral-600 transition duration-150 focus:outline-none"
        aria-label="Previous Feature"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path></svg
        >
      </button>
      <button
        type="button"
        onclick="document.getElementById('carousel-1').scrollBy({left: 320, behavior: 'smooth'})"
        class="p-2 rounded-full border border-neutral-200 bg-white hover:bg-neutral-50 text-neutral-300 hover:text-neutral-600 transition duration-150 focus:outline-none"
        aria-label="Next Feature"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          ><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path></svg
        >
      </button>
    </div>
  </section>

  <section class="w-full bg-black text-white py-24" data-header-theme="dark">
    <div class="w-full max-w-5xl mx-auto px-6 flex flex-col mb-12">
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight text-white">
        Engineered for speed.
      </h2>
      <p class="mt-4 text-neutral-300 leading-relaxed max-w-2xl">
        FynnCloud launches instantly, handles heavy synchronization tasks
        concurrently, and maintains a microscopic system footprint. Performance
        is built into the compiler.
      </p>
    </div>

    <div
      id="carousel-2"
      class="carousel-scroller w-full overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-none pb-4"
    >
      <div class="carousel-track flex gap-6 justify-start">
        <FastCard
          title="Powered by Swift."
          description="Compiled directly to native machine code. FynnCloud utilizes Swift's modern concurrency to handle thousands of requests with sub-millisecond latency."
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-blue-500 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
        </FastCard>

        <FastCard
          title="AI semantic search."
          description="Find files, PDFs, and images by meaning rather than filename. Auto-OCR extracts text to feed a multi-modal vector search index."
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-blue-500 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z"
            ></path>
          </svg>
        </FastCard>
        <FastCard
          title="Single-binary deployment."
          description="No Apache, no PHP-FPM pools, and no complex configuration files. Run the backend as a single statically-linked binary."
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-blue-500 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"
            ></path>
            <path d="m3.3 7 8.7 5 8.7-5"></path>
            <path d="M12 22V12"></path>
          </svg>
        </FastCard>
        <FastCard
          title="Zero-copy streaming."
          description="Stream multi-gigabyte uploads directly to your storage backend without buffering files in memory, keeping your server stable."
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-blue-500 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m16 6-4-4-4 4"></path>
            <path d="M12 2v8"></path>
            <rect width="20" height="8" x="2" y="14" rx="2"></rect>
            <path d="M6 18h.01"></path>
            <path d="M10 18h.01"></path>
          </svg>
        </FastCard>
        <FastCard
          title="Modern security."
          description="Features enterprise-ready user authentication, token-based API security, and seamless user directory integrations."
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-blue-500 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.8 17 5 19 5a1 1 0 0 1 1 1z"
            ></path>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
        </FastCard>
        <FastCard
          title="S3-compatible."
          description="Store files on local disks or offload them to any S3-compatible cloud storage provider with a simple configuration."
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-blue-500 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
            <path d="M3 5V19A9 3 0 0 0 21 19V5"></path>
            <path d="M3 12A9 3 0 0 0 21 12"></path>
          </svg>
        </FastCard>
        <FastCard
          title="Asynchronous job queues."
          description="Offload intensive tasks like thumbnail generation and OCR text extraction to background Redis worker queues to keep API latency sub-millisecond."
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-blue-500 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"
            ></path>
            <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path>
            <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"></path>
          </svg>
        </FastCard>
      </div>
    </div>

    <div
      class="w-full max-w-5xl mx-auto px-6 flex justify-end gap-2 mt-6 select-none"
    >
      <button
        type="button"
        onclick="document.getElementById('carousel-2').scrollBy({left: -260, behavior: 'smooth'})"
        class="p-2 rounded-full border border-white/10 hover:bg-white/5 text-neutral-300 transition duration-150 focus:outline-none"
        aria-label="Previous Feature Item"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path></svg
        >
      </button>
      <button
        type="button"
        onclick="document.getElementById('carousel-2').scrollBy({left: 260, behavior: 'smooth'})"
        class="p-2 rounded-full border border-white/10 hover:bg-white/5 text-neutral-300 transition duration-150 focus:outline-none"
        aria-label="Next Feature Item"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          ><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path></svg
        >
      </button>
    </div>
  </section>

  <section
    id="benchmarks"
    class="w-full bg-black text-white pb-24 flex justify-center"
    data-header-theme="dark"
  >
    <div class="w-full max-w-5xl px-6 flex flex-col">
      <div class="max-w-2xl mb-12">
        <h2 class="text-4xl font-semibold tracking-tight text-white mt-2">
          See how it stacks up.
        </h2>
        <p class="mt-4 text-neutral-300 leading-relaxed max-w-2xl">
          Verified by real-world side-by-side performance benchmarks running on
          a modest Raspberry Pi 5.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 w-full">
        <BenchmarkCard
          title="Sync Request Latency (TTFB)"
          fynncloudValue="12 ms"
          fynncloudPercent={5}
          nextcloudValue="240 ms"
          comparisonPercent="-95%"
          description="Response latency for a delta sync request"
        >
          <span slot="fynncloud-sub" class="text-neutral-500 font-normal"
            >(Swift + Vapor)</span
          >
        </BenchmarkCard>

        <BenchmarkCard
          title="Server Memory Footprint (Idle)"
          fynncloudValue="42 MB"
          fynncloudPercent={7}
          nextcloudValue="626 MB"
          nextcloudLabel="(Apache + FPM pool)"
          comparisonPercent="-93%"
          description="Memory consumption of idle backend services"
        />
      </div>
    </div>
  </section>

  <section
    id="pricing"
    class="w-full bg-white text-neutral-900 py-24 border-b border-neutral-200/50 relative"
    data-header-theme="light"
  >
    <div class="w-full max-w-5xl mx-auto px-6 relative z-10 flex flex-col">
      <!-- Section Header -->
      <div class="max-w-2xl mb-16">
        <h2
          class="text-4xl md:text-5xl font-extrabold tracking-tight text-neutral-900"
        >
          Fair. Scalable. Transparent.
        </h2>
        <p class="mt-4 text-neutral-600 leading-relaxed max-w-xl">
          We explicitly target the ignored 10-to-99-user segment with zero seat
          minimums, alongside a highly permissive free tier for homelabs.
        </p>
      </div>

      <!-- FynnCloud Cost Estimator -->
      <div
        class="w-full rounded-3xl bg-neutral-50 border border-neutral-200/60 p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)] mb-16"
      >
        <div
          class="flex flex-col lg:flex-row gap-10 items-center justify-between"
        >
          <div class="flex-1 w-full space-y-6">
            <div>
              <h3 class="text-2xl font-bold mt-2 text-neutral-900">
                How many users in your team?
              </h3>
              <p class="text-sm text-neutral-500 mt-1">
                Select your team size to estimate your self-hosted licensing
                costs and see which plan fits your requirements.
              </p>
            </div>

            <!-- Slider -->
            <div class="space-y-4">
              <div class="flex justify-between items-baseline">
                <span class="text-sm font-semibold text-neutral-700"
                  >Team Size</span
                >
                <span
                  class="text-3xl font-extrabold text-blue-600"
                  id="user-count-display"
                  >25 <span class="text-sm font-normal text-neutral-500"
                    >users</span
                  ></span
                >
              </div>
              <input
                type="range"
                id="user-range"
                min="1"
                max="150"
                value="25"
                class="w-full h-2 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-600/50"
              />
              <div
                class="flex justify-between text-xs text-neutral-400 font-medium"
              >
                <span>1 User (Homelab)</span>
                <span>50 Users</span>
                <span>100 Users</span>
                <span>150+ Users</span>
              </div>
            </div>
          </div>

          <!-- Vertical Divider on lg screens -->
          <div class="hidden lg:block w-[1px] h-40 bg-neutral-200"></div>

          <!-- Recommended Plan Display -->
          <div
            class="w-full lg:w-[22rem] bg-white border border-neutral-200/80 rounded-2xl p-6 flex flex-col gap-4 relative overflow-hidden shadow-sm"
          >
            <div class="flex flex-col gap-4 relative z-10">
              <!-- Pricing header -->
              <div>
                <span
                  class="text-xs font-semibold text-blue-600"
                  >Recommended Plan</span
                >
                <h4
                  class="text-lg font-extrabold text-neutral-900 mt-0.5"
                  id="fynncloud-calc-tier"
                >
                  Business Tier
                </h4>
                <div class="flex items-baseline mt-1.5">
                  <span
                    class="text-3xl font-extrabold text-blue-600"
                    id="fynncloud-calc-cost">$600</span
                  >
                  <span class="text-sm font-semibold text-neutral-500 ml-1"
                    >/ yr</span
                  >
                </div>
                <div
                  class="text-xs text-neutral-400 mt-1"
                  id="fynncloud-calc-breakdown"
                >
                  25 users × $2/mo × 12 mos
                </div>
              </div>

              <div class="border-t border-neutral-100 my-0.5"></div>

              <!-- Included Features -->
              <div class="space-y-2">
                <span
                  class="text-xs font-semibold text-neutral-500"
                  >Included Features</span
                >
                <ul
                  class="space-y-2 text-xs text-neutral-600"
                  id="fynncloud-calc-features"
                >
                  <!-- Will be populated dynamically via JavaScript -->
                </ul>
              </div>

              <!-- Dynamic CTA Button -->
              <div class="mt-2">
                <a
                  href="#"
                  id="fynncloud-calc-cta"
                  class="block w-full text-center bg-gradient-to-b from-blue-500 to-blue-700 hover:from-blue-600 hover:to-blue-800 active:scale-[0.98] text-white py-2.5 px-4 rounded-xl text-xs font-semibold shadow-[inset_0_1px_1px_rgba(255,255,255,0.3),0_2px_6px_rgba(37,99,235,0.25)] transition duration-150"
                >
                  Get Business License
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Pricing cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch mb-16">
        <!-- Homelab (Community) -->
        <PricingCard
          title="Homelab"
          subtitle="For developers, families, and self-hosters."
          price="$0"
          priceSuffix="Free forever"
          features={[
            { text: "Up to 10 active users", highlight: true },
            { text: "Native Finder sync & desktop apps" },
            { text: "AI semantic search & secure sharing" },
            { text: "Community support" },
          ]}
          ctaText="Get Started Free"
          ctaHref="https://github.com/FynnCloudProject"
        />

        <!-- Business (Business) -->
        <PricingCard
          title="Business"
          subtitle="For growing teams and professional organizations."
          price="$2"
          priceSuffix="/ user / mo"
          extraLabel="Billed annually • Cancel anytime"
          features={[
            { text: "Up to 100 active users", highlight: true },
            { text: "Everything in Homelab" },
            { text: "SSO & directory integrations" },
            { text: "Priority email support" },
          ]}
          ctaText="Get Started Now"
          ctaTier="business"
          highlighted={true}
        />

        <!-- Enterprise -->
        <PricingCard
          title="Enterprise"
          subtitle="For large-scale infrastructure and high-availability setups."
          price="$2,500"
          priceSuffix="/ yr"
          extraLabel="Flat-rate license • Unlimited users"
          features={[
            { text: "Unlimited active users", highlight: true },
            { text: "Everything in Business" },
            { text: "High-availability, multi-node & Kubernetes" },
            { text: "Priority SLA support" },
          ]}
          ctaText="Get Started Now"
          ctaTier="enterprise"
        />
      </div>
    </div>
  </section>

  <!-- Interactive script for calculator -->
  <script is:inline>
    (() => {
      const initCalculator = () => {
        const slider = document.getElementById("user-range");
        const userDisplay = document.getElementById("user-count-display");
        const fynncloudCost = document.getElementById("fynncloud-calc-cost");
        const fynncloudTier = document.getElementById("fynncloud-calc-tier");
        const fynncloudBreakdown = document.getElementById(
          "fynncloud-calc-breakdown",
        );
        const fynncloudFeatures = document.getElementById(
          "fynncloud-calc-features",
        );
        const fynncloudCTA = document.getElementById("fynncloud-calc-cta");

        if (
          !slider ||
          !userDisplay ||
          !fynncloudCost ||
          !fynncloudTier ||
          !fynncloudBreakdown ||
          !fynncloudFeatures ||
          !fynncloudCTA
        ) {
          return;
        }

        const tierDetails = {
          homelab: {
            features: [
              "Up to 10 active users",
              "Native Finder sync & desktop apps",
              "AI semantic search & secure sharing",
              "Community support",
            ],
            ctaText: "Get Started Free",
            ctaLink: "https://github.com/FynnCloudProject",
          },
          business: {
            features: [
              "Up to 100 active users",
              "Everything in Homelab",
              "SSO & directory integrations",
              "Priority email support",
            ],
            ctaText: "Get Started Now",
            ctaLink: "https://github.com/FynnCloudProject",
          },
          enterprise: {
            features: [
              "Unlimited active users",
              "Everything in Business",
              "High-availability, multi-node & Kubernetes",
              "Priority SLA support",
            ],
            ctaText: "Get Started Now",
            ctaLink: "https://github.com/FynnCloudProject",
          },
        };

        function updateCalculator() {
          const users = parseInt(slider.value, 10);

          // Update user display
          userDisplay.innerHTML = `${users} <span class="text-sm font-normal text-neutral-500">user${users > 1 ? "s" : ""}</span>`;

          let fynnAnnual = 0;
          let tierName = "";
          let fynnBreakdownText = "";
          let currentTierKey = "homelab";

          if (users <= 10) {
            fynnAnnual = 0;
            tierName = "Homelab Tier";
            fynnBreakdownText = "Free for homelab use";
            currentTierKey = "homelab";
          } else {
            const businessCost = users * 2 * 12;
            if (businessCost <= 2500) {
              fynnAnnual = businessCost;
              tierName = "Business Tier";
              fynnBreakdownText = `${users} users × $2/mo × 12 mos`;
              currentTierKey = "business";
            } else {
              fynnAnnual = 2500;
              tierName = "Enterprise Tier";
              currentTierKey = "enterprise";
              if (users < 100) {
                fynnBreakdownText = "Flat rate applied for cost savings";
              } else {
                fynnBreakdownText = "Flat rate, unlimited users";
              }
            }
          }

          fynncloudCost.textContent =
            fynnAnnual === 0 ? "$0" : `$${fynnAnnual.toLocaleString()}`;
          fynncloudTier.textContent = tierName;
          fynncloudBreakdown.textContent = fynnBreakdownText;

          // Update features list dynamically
          const tier = tierDetails[currentTierKey];
          fynncloudFeatures.innerHTML = tier.features
            .map(
              (feature) => `
              <li class="flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-blue-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>${feature}</span>
              </li>
            `,
            )
            .join("");

          // Update CTA button details
          fynncloudCTA.textContent = tier.ctaText;
          if (currentTierKey === "business") {
            fynncloudCTA.href = "#";
            fynncloudCTA.setAttribute("data-checkout-tier", "business");
            fynncloudCTA.setAttribute("data-quantity", users.toString());
            fynncloudCTA.removeAttribute("target");
          } else if (currentTierKey === "enterprise") {
            fynncloudCTA.href = "#";
            fynncloudCTA.setAttribute("data-checkout-tier", "enterprise");
            fynncloudCTA.setAttribute("data-quantity", "1");
            fynncloudCTA.removeAttribute("target");
          } else {
            fynncloudCTA.href = tier.ctaLink;
            fynncloudCTA.removeAttribute("data-checkout-tier");
            fynncloudCTA.removeAttribute("data-quantity");
            fynncloudCTA.setAttribute("target", "_blank");
          }
        }

        slider.addEventListener("input", updateCalculator);

        // Run initially to render matching UI
        updateCalculator();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCalculator);
      } else {
        initCalculator();
      }
    })();
  </script>

  <section
    class="w-full bg-[#EAECEF] text-neutral-500 py-16 flex justify-center"
    data-header-theme="light"
  >
    <div class="w-full max-w-5xl px-6 flex flex-col gap-10">
      <div
        class="text-[10px] text-neutral-500 space-y-2 border-b border-neutral-300 pb-8 leading-relaxed"
      >
        <p>
          1. TTFB (Time to First Byte) request latency benchmarks conducted in
          June 2026. Represents request execution overhead for sync delta polls
          in a clean schema state. Testing performed on a Raspberry Pi 5 (4GB
          RAM) hosting a release-mode FynnCloud server binary comparing against
          Nextcloud Enterprise v29 running in Apache with PHP-FPM container
          wrapper.
        </p>
        <p>
          2. Server Memory Footprint represents base resident set size (RSS)
          utilization when starting up services in an idle state. Nextcloud
          Enterprise base configuration includes Apache, Redis cache database,
          and active PHP-FPM worker pools. FynnCloud runs as a compiled
          statically linked standalone server executable.
        </p>
        <p>
          3. FynnCloud project is currently in early alpha stage of development.
          The APIs, desktop sync logic, and database schemas are subject to
          change. Not recommended for production storage deployments.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex items-center justify-center select-none gap-3">
          <img
            src="/img/logo.svg"
            alt="FynnCloud Footer Logo"
            class="h-10 w-auto"
          />
          <p class="text-lg font-light leading-none">
            FynnCloud<br />
            <span class="text-xs text-neutral-400 tracking-tight">© 2026</span>
          </p>
        </div>
        <div
          class="flex items-center gap-4 text-xs font-semibold text-neutral-500"
        >
          <a
            class="hover:text-neutral-800 transition duration-150"
            href="https://github.com/FynnCloudProject"
            target="_blank"
            rel="noopener">GitHub</a
          >
          <span class="text-neutral-300 font-normal select-none">•</span>
          <a
            class="hover:text-neutral-800 transition duration-150"
            href="https://github.com/FynnCloudProject/fynncloud.ch"
            target="_blank"
            rel="noopener">Website Source</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Checkout is handled by the shared subscribe page on the portal -->
  <script define:vars={{ portalUrl }} is:inline>
    (() => {
      const goToCheckout = (e) => {
        const target = e.target.closest("[data-checkout-tier]");
        if (!target) return;
        e.preventDefault();
        const tier = target.getAttribute("data-checkout-tier") || "business";
        const quantity = target.getAttribute("data-quantity");
        const params = new URLSearchParams({ tier });
        if (quantity) params.set("seats", quantity);
        window.location.href = `${portalUrl}/subscribe?${params.toString()}`;
      };
      document.addEventListener("click", goToCheckout);
    })();
  </script>
</Layout>
