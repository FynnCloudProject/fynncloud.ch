---
import "../styles/global.css";

interface Props {
    title?: string;
}

const { title = "FynnCloud – Self-Hosted Cloud Storage" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href="/img/logo.png" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <meta
            name="description"
            content="FynnCloud - a self-hosted cloud storage solution built with Swift and Nuxt."
        />
        <link
            rel="icon"
            type="image/png"
            href="/img/favicon-96x96.png"
            sizes="96x96"
        />
        <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
        <link rel="shortcut icon" href="/img/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/img/apple-touch-icon.png"
        />
        <meta name="apple-mobile-web-app-title" content="FynnCloud" />
        <link rel="manifest" href="/site.webmanifest" />
        <title>{title}</title>
    </head>
    <body class="min-h-screen bg-zinc-950 font-sans antialiased text-zinc-100">
        <div class="mx-auto flex min-h-screen max-w-4xl flex-col gap-12 px-6 py-10">
            <header class="flex items-center justify-between rounded-2xl bg-linear-to-b from-neutral-800/90 to-neutral-900/95 px-5 py-3 backdrop-blur-xl shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_1px_3px_rgba(0,0,0,0.3),0_2px_8px_rgba(0,0,0,0.2)] border border-white/5">
                <a href="/" class="flex items-center gap-2.5">
                    <img src="/img/logo.png" alt="FynnCloud" class="h-7" />
                    <span class="text-2xl font-light text-white">FynnCloud</span>
                </a>
                <nav class="flex items-center gap-4 text-sm text-zinc-400">
                    <a class="hover:text-zinc-100 transition duration-150" href="https://github.com/FynnCloudProject" target="_blank" rel="noopener">GitHub</a>
                </nav>
            </header>
            <main class="flex-1">
                <slot />
            </main>
            <footer class="border-t border-white/5 pt-6 text-xs text-zinc-600">
                © FynnCloud · <a class="hover:text-zinc-400 transition duration-150" href="https://github.com/FynnCloudProject" target="_blank" rel="noopener">Source</a>
            </footer>
        </div>
    </body>
</html>
